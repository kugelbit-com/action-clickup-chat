{
  "name": "action-clickup-chat",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist pnpm-lock.yaml node_modules",
    "bundle": "run format:write && run package",
    "ci-test": "jest",
    "format:write": "prettier --cache --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache --cache-strategy content --report-unused-disable-directives .",
    "package": "tsc && ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "package:watch": "run package --watch",
    "test": "jest --coverage --verbose",
    "prepublishOnly": "run clean && install && run build",
    "preflight": "install && run format:write && run lint && run test && run package"
  },
  "keywords": [
    "actions"
  ],
  "author": "Giovanni Silva",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "axios": "^1.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/ncc": "^0.44.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "rimraf": "6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
